server:
  ws_url: "wss://www.zzzjc.xin/api/ws/image-worker"
  token: "CHANGE_ME"
  worker_id: "pi-b4-001"
  reconnect_sec: 5
  ping_interval_sec: 30

oss:
  endpoint: "oss-cn-xxx.aliyuncs.com"
  access_key_id: ""
  access_key_secret: ""
  bucket: ""
  custom_domain: ""

worker:
  max_concurrent: 2
  temp_dir: "/tmp/recipe-image"

compress:
  oxipng_path: "/usr/local/bin/oxipng"
  oxipng_flags: ["-o", "4", "--strip", "safe"]
  oxipng_threads: 4
  cjpeg_path: "/usr/local/bin/cjpeg"
  djpeg_path: "/usr/local/bin/djpeg"
  cjpeg_quality: 85
  magick_path: "/usr/bin/magick"
  ffmpeg_path: "/usr/bin/ffmpeg"

firdgemate:
  model_path: "/home/zjc/recipe-image/models/culinaryvision.onnx"
  onnx_lib_path: "/home/zjc/local/lib/libonnxruntime.so"
  num_classes: 47
  conf_threshold: 0.30
  iou_threshold: 0.5
  input_size: 640
  intra_op_threads: 4
